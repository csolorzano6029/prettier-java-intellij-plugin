<idea-plugin>
    <id>com.prettierjavaplugin</id>
    <name>Prettier Java</name>
    <version>1.0.0</version>
    <vendor>Carlos Solórzano</vendor>

    <description><![CDATA[
        Format Java files using <b>Prettier</b> with <code>prettier-plugin-java</code>.<br><br>
        <ul>
            <li><b>Zero-latency:</b> Uses an embedded V8 engine (Javet). No external Node.js required.</li>
            <li><b>Ctrl+Alt+L:</b> Replaces or complements the built-in formatter.</li>
            <li><b>Format on Save:</b> Automatically formats your code when you save (Ctrl+S).</li>
            <li><b>Highly Configurable:</b> Tab width, print width, semicolons, and more in settings.</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Formatter: Ctrl+Alt+L -->
        <formattingService
                implementation="com.prettierjavaplugin.PrettierJavaFormattingService"/>

        <!-- Settings: Settings → Tools → Prettier Java -->
        <applicationConfigurable
                parentId="tools"
                instance="com.prettierjavaplugin.PrettierJavaSettingsConfigurable"
                id="com.prettierjavaplugin.settings"
                displayName="Prettier Java"/>

        <!-- Persistent settings -->
        <applicationService
                serviceImplementation="com.prettierjavaplugin.PrettierJavaSettings"/>
    </extensions>

    <actions>
        <!--
            overrides="true" completely replaces IntelliJ's built-in SaveAll (Ctrl+S).
            No shortcut conflicts. Our action handles all save cases:
            - Java file + Format on Save ON → format then save
            - Anything else → save normally
        -->
        <action id="SaveAll"
                class="com.prettierjavaplugin.PrettierJavaFormatAndSaveAction"
                text="Save All"
                description="Save all documents, formatting Java files if enabled"
                overrides="true">
            <add-to-group group-id="FileMenu" anchor="after" relative-to-action="SaveDocument"/>
        </action>
    </actions>
</idea-plugin>
